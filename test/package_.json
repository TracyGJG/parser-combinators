{
  "name": "orange-duck-parser",
  "version": "1.0.0",
  "description": "Parser ሴ code based on the article [\"You could have invented parser combinators\"](https://theorangeduck.com/page/you-could-have-invented-parser-combinators) by Daniel Holden (aka Orange Duck)",
  "main": "index.js",
  "directories": { "test": "test" },
  "type": "module",
  "scripts": {
    "test": "node --test",
    "watch": "node --test --watch",
    "coverage": "c8 node --test",
    "coverage:ui": "http-server ./coverage -o lcov-report/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TracyGJG/orange-duck-parser.git"
  },
  "keywords": ["JSON", "Parser", "Combinators"],
  "author": "TGJ Gilmore",
  "license": "CC0-1.0",
  "devDependencies": {
    "c8": "^10.1.3",
    "http-server": "^14.1.1"
  },
  "c8": {
    "exclude": ["./*.test.*"],
    "reporter": ["lcov", "html"]
  },
  "bugs": {
    "url": "https://github.com/TracyGJG/orange-duck-parser/issues"
  },
  "homepage": "https://github.com/TracyGJG/orange-duck-parser#readme"
}
